# 📱 Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 🔑 Twelve Data API Keys (comma-separated, no spaces)
TWELVEDATA_API_KEYS=key1,key2,key3,key4,key5
